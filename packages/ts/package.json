{
  "name": "@oleary-labs/signet-circuits",
  "version": "0.1.0",
  "description": "Compiled Signet zk circuit artifacts (bytecode + verification key) and pinned toolchain version constants. Consumed by the UI.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./artifacts/*": "./dist/artifacts/*"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/copy-artifacts.mjs && tsc",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@aztec/bb.js": "3.0.0-nightly.20251104",
    "@noir-lang/noir_js": "1.0.0-beta.15"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signet-protocol/signet-circuits.git",
    "directory": "packages/ts"
  },
  "license": "UNLICENSED",
  "private": false,
  "publishConfig": {
    "access": "public"
  }
}
